# Gemini API key — provided by Axio Education
GEMINI_API_KEY=your_gemini_api_key_here

# GCP Project settings — provided by Axio Education
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_REGION=us-central1

# Cloud Storage bucket name — create this in GCP Console
GCS_BUCKET_NAME=marginmind-docs

# Cloud Tasks queue settings — set up in GCP Console
CLOUD_TASKS_QUEUE=marginmind-queue